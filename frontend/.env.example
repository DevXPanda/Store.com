# ── Convex (required) ───────────────────────────────────────────────────────
# Get from: npx convex dev (shows URL after first run)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── Groq AI (optional) ───────────────────────────────────────────────────────
# Get free API key from: https://console.groq.com
# Model used: llama3-70b-8192 (free tier, very fast)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=vegfru-super-secret-jwt-key-change-in-production
