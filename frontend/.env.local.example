# ════════════════════════════════════════════════════════════════
#  VegFru Frontend — All Environment Variables
#  Copy to .env.local and fill your values
# ════════════════════════════════════════════════════════════════

# ── Convex DB (REQUIRED — run: cd backend && npx convex dev) ──
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ── JWT Auth (REQUIRED) ───────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=your-random-32-char-secret-key-here-minimum

# ── Groq AI — Leafy assistant (RECOMMENDED, free) ─────────────
# Get key: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Razorpay — Online Payments (REQUIRED for UPI/Card) ────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Resend — Email Confirmations (RECOMMENDED, free) ──────────
# Get from: https://resend.com → API Keys → Create
# Free: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=orders@yourdomain.com

# ── Fast2SMS — SMS Notifications (OPTIONAL) ───────────────────
# Get from: https://www.fast2sms.com → API → DLT Route
# Cost: ~₹0.15–0.25 per SMS
FAST2SMS_API_KEY=your-fast2sms-api-key

# ── App URL (REQUIRED for production SEO + emails) ─────────────
NEXT_PUBLIC_APP_URL=https://vegfru.in

# ── Google Analytics (OPTIONAL) ────────────────────────────────
# Get from: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
