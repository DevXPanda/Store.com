# Env is loaded from backend/.env and backend/.env.local (see backend/.env.local.example).
#
# Optional: send customer/delivery password login to Render API (same Convex users table as local /api/auth/login)
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com
#
# Nodemailer (SMTP) — OTP, order emails, password reset
# Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
# SMTP_USER=you@gmail.com  SMTP_PASS=<16-char App Password, not your Gmail password>
# FROM_EMAIL=you@gmail.com
