# ════════════════════════════════════════════════════════════════
#  VegFru Admin Panel — Environment Variables
# ════════════════════════════════════════════════════════════════

# ── Convex DB (REQUIRED — same URL as frontend) ───────────────
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ── JWT Secret (REQUIRED — MUST match frontend exactly) ───────
JWT_SECRET=your-random-32-char-secret-key-here-minimum

# Optional — landing page links (defaults to localhost ports)
# NEXT_PUBLIC_STORE_URL=http://localhost:3000
# NEXT_PUBLIC_SUPERADMIN_URL=http://localhost:3003

# ── Twilio Verify SMS OTP (REQUIRED for phone sign-in) ─────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
