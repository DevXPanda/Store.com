# ════════════════════════════════════════════════════════════════
#  VegFru Delivery Panel — Environment Variables
# ════════════════════════════════════════════════════════════════
#
# Copy this file to .env.local and set the URL (must match admin-panel & frontend).
# From repo root: backend/ → run `npx convex dev` — use the printed deployment URL.
#
# ── Convex DB (REQUIRED) ───────────────────────────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Optional
# NEXT_PUBLIC_STORE_URL=http://localhost:3000
