# ════════════════════════════════════════════════════════════════
#  VegFru — single env file for all apps (frontend, admin, delivery, superadmin)
#  Copy to .env.local and fill values. Run Convex from backend/ (npx convex dev).
# ════════════════════════════════════════════════════════════════

# ── Convex DB (REQUIRED — same URL everywhere) ─────────────────
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# ── JWT (REQUIRED — must match across all panels) ───────────────
JWT_SECRET=your-random-32-char-secret-key-here-minimum

# ── Groq AI — Leafy assistant (optional) ─────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Razorpay — payments (frontend checkout) ─────────────────────
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# ── Nodemailer (SMTP) — email OTP + order emails (frontend API routes) ──
# Gmail: use an App Password (Security → 2-Step Verification → App passwords), not your login password.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# FROM_EMAIL=you@gmail.com

# ── Twilio Verify — SMS OTP (admin + customer phone) ────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# ── Twilio SMS — delivery partner OTP (Messaging API) ───────────
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Fast2SMS — SMS (optional) ───────────────────────────────────
FAST2SMS_API_KEY=your-fast2sms-api-key

# ── Render API (optional — for Vercel storefront/delivery login via Render) ──
# On Vercel (frontend + delivery projects): NEXT_PUBLIC_BACKEND_URL=https://your-service.onrender.com
# On this Render service: optional ALLOWED_ORIGIN=https://your-storefront.vercel.app (or * for dev)

# ── App URLs ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STORE_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_DELIVERY_URL=http://localhost:3002
NEXT_PUBLIC_SUPERADMIN_URL=http://localhost:3003

# ── Google Analytics (optional) ─────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
